---
const faviconBase = `${import.meta.env.BASE_URL}favicon/`;
---

<link rel="manifest" href={`${faviconBase}site.webmanifest`} />
<link rel="shortcut icon" href={`${faviconBase}favicon.ico`} />
<link rel="icon" type="image/svg+xml" href={`${faviconBase}favicon.svg`} />
<link rel="icon" type="image/png" sizes="96x96" href={`${faviconBase}favicon-96x96.png`} />
<link rel="apple-touch-icon" sizes="180x180" href={`${faviconBase}apple-touch-icon.png`} />
<link rel="mask-icon" href={`${faviconBase}favicon.svg`} color="#0f172a" />
