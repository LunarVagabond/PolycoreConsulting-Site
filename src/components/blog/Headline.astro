---
interface Props {
  subtitle?: string;
}

const { subtitle: subtitleProp } = Astro.props as Props;
const title = await Astro.slots.render('default');
const subtitleFromSlot = await Astro.slots.render('subtitle');
const subtitleHtml = subtitleFromSlot?.trim() ? subtitleFromSlot : subtitleProp;
---

<header class="mb-8 md:mb-16 text-center max-w-3xl mx-auto">
  <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading" set:html={title} />
  {
    subtitleHtml && (
      <div class="mt-2 md:mt-3 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium" set:html={subtitleHtml} />
    )
  }
</header>
