---
import { SITE } from 'astrowind:config';

const logoSrc = `${import.meta.env.BASE_URL}PCCTransparent.png`;
---

<span class="inline-flex items-center gap-2 self-center ml-2 rtl:ml-0 rtl:mr-2 whitespace-nowrap">
  <img
    src={logoSrc}
    alt=""
    width="500"
    height="500"
    class="h-9 w-auto md:h-8 shrink-0"
    decoding="async"
  />
  <span class="text-2xl md:text-xl font-bold text-gray-900 dark:text-white">{SITE?.name}</span>
</span>
